---
import AppLayout from '../../layouts/AppLayout.astro';
import NumberSearch from '../../components/islands/NumberSearch.tsx';
---

<AppLayout title="Search — Ringdocket">
  <div class="search-page">
    <header class="search-head">
      <p class="search-kicker">Number lookup</p>
      <h1 class="search-h1">
        Check a number. <em>See what the record says.</em>
      </h1>
      <p class="search-lead">
        Every number on the Ringdocket block list has a public record — three
        distinct accounts corroborated it within 14 days. Search below to see
        whether a number is listed, which campaign it belongs to, and how
        many reports it has accumulated.
      </p>
    </header>

    <div class="search-panel">
      <NumberSearch client:load />
    </div>
  </div>
</AppLayout>

<style is:global>
  .search-page {
    max-width: 760px;
  }
  .search-head {
    margin-bottom: 2rem;
  }
  .search-kicker {
    font-family: 'JetBrains Mono';
    font-size: 0.75rem;
    color: var(--accent-signal);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 0.875rem;
  }
  .search-h1 {
    font-family: 'Bricolage Grotesque';
    font-weight: 700;
    font-size: clamp(1.875rem, 4vw, 2.5rem);
    line-height: 1.05;
    letter-spacing: -0.015em;
    margin: 0 0 0.875rem;
    color: var(--ink-primary);
  }
  .search-h1 em {
    font-family: 'Newsreader';
    font-style: italic;
    font-weight: 500;
    color: var(--ink-secondary);
  }
  .search-lead {
    font-family: 'Newsreader';
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--ink-secondary);
    max-width: 62ch;
    margin: 0;
  }

  .search-panel {
    background: var(--surface-raised);
    border: 1px solid var(--rule);
    border-radius: 10px;
    padding: clamp(1.5rem, 3vw, 2.25rem);
    margin-bottom: 2rem;
  }

  .search-shell {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .search-form {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .search-label {
    font-family: 'Inter Tight';
    font-weight: 500;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-secondary);
  }
  .search-input-row {
    display: flex;
    gap: 0.5rem;
    align-items: stretch;
    flex-wrap: wrap;
  }
  .search-input {
    flex: 1 1 260px;
    min-width: 0;
    font-family: 'JetBrains Mono';
    font-size: 1.0625rem;
    padding: 0.75rem 0.875rem;
    border: 1px solid var(--rule);
    border-radius: 6px;
    background: var(--surface-paper);
    color: var(--ink-primary);
    transition: border-color 140ms ease-out;
  }
  .search-input:focus {
    outline: none;
    border-color: var(--ink-primary);
  }
  .search-submit {
    font-family: 'Inter Tight';
    font-weight: 500;
    font-size: 0.9375rem;
    padding: 0.75rem 1.25rem;
    border-radius: 6px;
    border: 1px solid transparent;
    background: var(--ink-primary);
    color: var(--surface-paper);
    cursor: pointer;
    transition: background 140ms ease-out;
  }
  .search-submit:hover:not(:disabled) {
    background: #2a2f3a;
  }
  .search-submit:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }
  .search-clear {
    font-family: 'Inter Tight';
    font-weight: 500;
    font-size: 0.875rem;
    padding: 0.75rem 0.875rem;
    border-radius: 6px;
    border: 1px solid var(--rule);
    background: transparent;
    color: var(--ink-secondary);
    cursor: pointer;
    transition: color 140ms ease-out, background 140ms ease-out;
  }
  .search-clear:hover {
    background: var(--surface-inset);
    color: var(--ink-primary);
  }
  .search-hint {
    font-family: 'Newsreader';
    font-size: 0.8125rem;
    color: var(--ink-byline);
    margin: 0;
  }

  .search-result {
    min-height: 120px;
  }
  .search-empty {
    font-family: 'Newsreader';
    font-style: italic;
    font-size: 1rem;
    color: var(--ink-byline);
    margin: 0;
    padding: 1.25rem 0;
    border-top: 1px solid var(--rule-subtle);
  }
  .search-error {
    font-family: 'Newsreader';
    font-size: 0.9375rem;
    color: #b1271b;
    margin: 0;
    padding: 1rem 0;
  }

  .search-card {
    padding: 1.25rem 0 0;
    border-top: 1px solid var(--rule);
  }
  .search-card-head {
    margin-bottom: 1rem;
  }
  .search-case-id {
    font-family: 'JetBrains Mono';
    font-size: 0.6875rem;
    color: var(--ink-byline);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 0.625rem;
  }
  .search-card.found .search-case-id {
    color: var(--ink-primary);
  }
  .search-phone {
    font-family: 'JetBrains Mono';
    font-weight: 500;
    font-size: 1.5rem;
    color: var(--ink-primary);
    margin: 0 0 0.75rem;
    letter-spacing: 0.01em;
  }
  .search-chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .search-chip {
    font-family: 'Inter Tight';
    font-weight: 500;
    font-size: 0.75rem;
    padding: 0.3125rem 0.625rem;
    border-radius: 4px;
    letter-spacing: 0.02em;
    text-decoration: none;
    display: inline-block;
  }
  .search-chip.corroborated {
    background: color-mix(in srgb, var(--signal-corroborated, #3f7c5a) 14%, var(--surface-raised));
    color: var(--signal-corroborated, #3f7c5a);
    border: 1px solid color-mix(in srgb, var(--signal-corroborated, #3f7c5a) 25%, transparent);
    text-transform: lowercase;
  }
  .search-chip.retired {
    background: var(--surface-inset);
    color: var(--ink-secondary);
    border: 1px solid var(--rule);
    text-transform: lowercase;
  }
  .search-chip.pending {
    background: var(--surface-inset);
    color: var(--ink-secondary);
    border: 1px solid var(--rule);
    text-transform: lowercase;
  }
  .search-chip.campaign-link {
    background: var(--surface-paper);
    color: var(--ink-primary);
    border: 1px solid var(--rule);
    transition: border-color 140ms ease-out, color 140ms ease-out;
  }
  .search-chip.campaign-link:hover {
    border-color: var(--ink-primary);
  }

  .search-facts {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0;
    margin: 0 0 1.25rem;
    padding: 0.875rem 0;
    border-top: 1px solid var(--rule-subtle);
    border-bottom: 1px solid var(--rule-subtle);
  }
  .search-fact {
    padding: 0.25rem 1rem 0.25rem 0;
    border-right: 1px solid var(--rule-subtle);
  }
  .search-fact:last-child {
    border-right: none;
  }
  .search-fact dt {
    font-family: 'Inter Tight';
    font-weight: 500;
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-byline);
    margin: 0 0 0.375rem;
  }
  .search-fact dd {
    font-family: 'JetBrains Mono';
    font-size: 0.9375rem;
    color: var(--ink-primary);
    margin: 0;
    line-height: 1.3;
  }
  .search-fact-unit {
    color: var(--ink-byline);
    font-size: 0.75rem;
  }

  .search-narrative {
    font-family: 'Newsreader';
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--ink-secondary);
    margin: 0 0 1.25rem;
    max-width: 58ch;
  }

  .search-card-foot {
    display: flex;
    gap: 1.25rem;
    align-items: baseline;
    padding-top: 0.5rem;
  }
  .search-foot-link {
    font-family: 'Inter Tight';
    font-weight: 500;
    font-size: 0.875rem;
    color: var(--ink-secondary);
    text-decoration: none;
    transition: color 140ms ease-out;
  }
  .search-foot-link:hover {
    color: var(--ink-primary);
  }
  .search-foot-muted {
    font-family: 'Newsreader';
    font-style: italic;
    font-size: 0.875rem;
    color: var(--ink-byline);
  }

  .search-skel {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem 0 0;
    border-top: 1px solid var(--rule-subtle);
  }
  .search-skel > div {
    background: linear-gradient(
      90deg,
      var(--surface-inset) 0%,
      color-mix(in srgb, var(--surface-inset) 60%, var(--surface-raised)) 50%,
      var(--surface-inset) 100%
    );
    border-radius: 3px;
    animation: rd-skel 1.4s ease-in-out infinite;
  }
  .search-skel-phone { width: 55%; height: 28px; }
  .search-skel-meta { width: 40%; height: 16px; }
  .search-skel-body { width: 85%; height: 60px; margin-top: 0.5rem; }
</style>
