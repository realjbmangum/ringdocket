---
import AppLayout from '../../layouts/AppLayout.astro';
import MyImpactTimeline from '../../components/islands/MyImpactTimeline.tsx';
import MyImpactAnalytics from '../../components/islands/MyImpactAnalytics.tsx';
---

<AppLayout title="My Impact — Ringdocket">
  <div class="impact-page">
    <header class="impact-head">
      <p class="impact-kicker">My Impact</p>
      <h1 class="impact-h1">
        Your work, <em>itemized.</em>
      </h1>
      <p class="impact-lead">
        Every number you've flagged, with its corroboration state, category,
        and first-flag credit. The record speaks for itself.
      </p>
    </header>
    <MyImpactAnalytics client:load />
    <MyImpactTimeline client:load />
  </div>
</AppLayout>

<style is:global>
  .impact-page {
    max-width: 820px;
  }
  .impact-head {
    margin-bottom: 2rem;
  }
  .impact-kicker {
    font-family: 'JetBrains Mono';
    font-size: 0.75rem;
    color: var(--accent-signal);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 0.875rem;
  }
  .impact-h1 {
    font-family: 'Bricolage Grotesque';
    font-weight: 700;
    font-size: clamp(1.875rem, 3.6vw, 2.5rem);
    line-height: 1.05;
    letter-spacing: -0.015em;
    margin: 0 0 0.875rem;
    color: var(--ink-primary);
  }
  .impact-h1 em {
    font-family: 'Newsreader';
    font-style: italic;
    font-weight: 500;
    color: var(--ink-secondary);
  }
  .impact-lead {
    font-family: 'Newsreader';
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--ink-secondary);
    max-width: 56ch;
    margin: 0;
  }

  .impact-summary {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
    border: 1px solid var(--rule);
    border-radius: 8px;
    background: var(--surface-raised);
    margin: 0 0 1.75rem;
    overflow: hidden;
  }
  .impact-summary-item {
    padding: 1rem 1.125rem;
    border-right: 1px solid var(--rule-subtle);
  }
  .impact-summary-item:last-child {
    border-right: none;
  }
  .impact-summary-item dt {
    font-family: 'Inter Tight';
    font-weight: 500;
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-byline);
    margin: 0 0 0.375rem;
  }
  .impact-summary-item dd {
    font-family: 'Bricolage Grotesque';
    font-weight: 700;
    font-size: 1.5rem;
    line-height: 1;
    color: var(--ink-primary);
    margin: 0;
  }

  .impact-timeline {
    list-style: none;
    margin: 0;
    padding: 0;
    border: 1px solid var(--rule);
    border-radius: 8px;
    background: var(--surface-raised);
    overflow: hidden;
  }
  .impact-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem;
    padding: 0.875rem 1.125rem;
    border-bottom: 1px solid var(--rule-subtle);
    align-items: center;
  }
  .impact-row:last-child {
    border-bottom: none;
  }
  .impact-row-main {
    display: flex;
    flex-direction: column;
    gap: 0.1875rem;
    min-width: 0;
  }
  .impact-phone {
    font-family: 'JetBrains Mono';
    font-size: 0.9375rem;
    color: var(--ink-mono);
  }
  .impact-meta {
    font-family: 'Newsreader';
    font-size: 0.8125rem;
    color: var(--ink-byline);
  }
  .impact-firstflag {
    font-family: 'Inter Tight';
    font-weight: 500;
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent-signal);
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    white-space: nowrap;
  }
  .impact-firstflag-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-signal);
  }
  .impact-seq {
    font-family: 'JetBrains Mono';
    font-size: 0.6875rem;
    color: var(--ink-byline);
    white-space: nowrap;
  }

  .impact-section {
    margin-bottom: 1.75rem;
  }
  .impact-section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 0.625rem;
    padding: 0 0.125rem;
  }
  .impact-section-title {
    font-family: 'Inter Tight';
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-primary);
    margin: 0;
  }
  .impact-section-meta {
    font-family: 'JetBrains Mono';
    font-size: 0.6875rem;
    color: var(--ink-byline);
  }
  .impact-row-pending {
    grid-template-columns: 1fr minmax(220px, auto);
    align-items: start;
  }
  .impact-pending-state {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    min-width: 180px;
    align-items: flex-end;
  }
  .impact-pending-label {
    font-family: 'JetBrains Mono';
    font-size: 0.8125rem;
    color: var(--ink-primary);
  }
  .impact-pending-bar {
    width: 100%;
    height: 4px;
    background: var(--surface-inset);
    border-radius: 2px;
    overflow: hidden;
  }
  .impact-pending-bar-fill {
    height: 100%;
    background: var(--accent-signal);
    transition: width 240ms ease-out;
  }
  .impact-pending-note {
    font-family: 'JetBrains Mono';
    font-size: 0.6875rem;
    color: var(--ink-byline);
  }
  .impact-empty-link {
    font-family: 'JetBrains Mono';
    font-size: 0.9375rem;
    color: var(--accent-signal);
    text-decoration: none;
  }
  .impact-empty-link:hover {
    text-decoration: underline;
  }

  .impact-empty {
    padding: 2.5rem 1.5rem;
    border: 1px dashed var(--rule);
    border-radius: 8px;
    background: var(--surface-raised);
    text-align: center;
  }
  .impact-empty-head {
    font-family: 'Newsreader';
    font-style: italic;
    font-size: 1.125rem;
    color: var(--ink-primary);
    margin: 0 0 0.5rem;
  }
  .impact-empty-body {
    font-family: 'Newsreader';
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--ink-secondary);
    margin: 0 auto;
    max-width: 46ch;
  }

  .impact-skel, .impact-error {
    font-family: 'Newsreader';
    font-size: 0.9375rem;
    color: var(--ink-byline);
  }
  .impact-skel-row {
    height: 54px;
    background: linear-gradient(
      90deg,
      var(--surface-inset) 0%,
      color-mix(in srgb, var(--surface-inset) 60%, var(--surface-raised)) 50%,
      var(--surface-inset) 100%
    );
    border-radius: 4px;
    margin-bottom: 0.5rem;
    animation: rd-skel 1.4s ease-in-out infinite;
  }
  @keyframes rd-skel {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 1; }
  }
  .impact-error { color: #b1271b; }

  /* Analytics section */
  .impact-analytics {
    display: grid;
    gap: 1rem;
    margin: 0 0 1.75rem;
  }
  .impact-analytics-card {
    border: 1px solid var(--rule);
    border-radius: 8px;
    background: var(--surface-raised);
    padding: 1.125rem 1.25rem 1rem;
  }
  .impact-analytics-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin: 0 0 0.875rem;
  }
  .impact-analytics-title {
    font-family: 'Inter Tight';
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-primary);
    margin: 0;
  }
  .impact-analytics-meta {
    font-family: 'JetBrains Mono';
    font-size: 0.6875rem;
    color: var(--ink-byline);
  }

  /* Weekly bar chart */
  .impact-analytics-chart-wrap {
    width: 100%;
  }
  .impact-analytics-chart {
    display: block;
    width: 100%;
    height: 120px;
    overflow: visible;
  }
  .impact-analytics-bar {
    fill: var(--ink-primary);
    opacity: 0.82;
  }
  .impact-analytics-bar:hover {
    opacity: 1;
  }
  .impact-analytics-bar-empty {
    fill: var(--ink-byline);
    opacity: 0.35;
  }
  .impact-analytics-baseline {
    stroke: var(--rule);
    stroke-width: 1;
  }
  .impact-analytics-xlabel {
    font-family: 'JetBrains Mono';
    font-size: 10px;
    fill: var(--ink-byline);
  }

  /* Category list */
  .impact-analytics-cats {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.625rem;
  }
  .impact-analytics-cat {
    display: grid;
    grid-template-columns: minmax(140px, 1fr) minmax(0, 2.4fr) auto;
    align-items: center;
    gap: 0.875rem;
  }
  .impact-analytics-cat-name {
    font-family: 'Newsreader';
    font-size: 0.9375rem;
    color: var(--ink-primary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .impact-analytics-cat-bar {
    height: 8px;
    background: var(--surface-inset);
    border-radius: 2px;
    overflow: hidden;
  }
  .impact-analytics-cat-bar-fill {
    height: 100%;
    background: var(--ink-secondary, var(--ink-primary));
    opacity: 0.78;
    transition: width 240ms ease-out;
  }
  .impact-analytics-cat-count {
    font-family: 'JetBrains Mono';
    font-size: 0.8125rem;
    color: var(--ink-mono, var(--ink-primary));
    min-width: 2ch;
    text-align: right;
  }

  /* Skeleton */
  .impact-analytics-skel {
    display: grid;
    gap: 1rem;
    margin: 0 0 1.75rem;
  }
  .impact-analytics-skel-card {
    height: 150px;
    border: 1px solid var(--rule);
    border-radius: 8px;
    background: linear-gradient(
      90deg,
      var(--surface-inset) 0%,
      color-mix(in srgb, var(--surface-inset) 60%, var(--surface-raised)) 50%,
      var(--surface-inset) 100%
    );
    animation: rd-skel 1.4s ease-in-out infinite;
  }
</style>
