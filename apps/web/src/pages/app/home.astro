---
import AppLayout from '../../layouts/AppLayout.astro';
---

<AppLayout title="Home — Ringdocket">
  <div class="home-stub">
    <p class="stub-kicker">Home</p>
    <h1 class="stub-h1">
      You're in. <em>Dashboard coming in chunk 2.</em>
    </h1>
    <p class="stub-lead">
      Next we'll render the narrative-led hero and live Network Ledger here.
      For now this is just proof that auth works — you're signed in and the
      guard let you through.
    </p>
    <div class="stub-links">
      <a href="/app/campaigns" class="stub-link">Campaigns →</a>
      <a href="/app/my-impact" class="stub-link">My Impact →</a>
      <a href="/app/settings" class="stub-link">Settings →</a>
    </div>
  </div>
</AppLayout>

<style>
  .home-stub {
    padding-top: 1.5rem;
  }
  .stub-kicker {
    font-family: 'JetBrains Mono';
    font-size: 0.75rem;
    color: var(--accent-signal);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 0.75rem;
  }
  .stub-h1 {
    font-family: 'Bricolage Grotesque';
    font-weight: 700;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
    margin: 0 0 1rem;
    color: var(--ink-primary);
  }
  .stub-h1 em {
    font-family: 'Newsreader';
    font-style: italic;
    font-weight: 500;
    color: var(--ink-secondary);
  }
  .stub-lead {
    font-family: 'Newsreader';
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--ink-secondary);
    max-width: 56ch;
    margin: 0 0 2rem;
  }
  .stub-links {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    padding-top: 1.25rem;
    border-top: 1px solid var(--rule-subtle);
  }
  .stub-link {
    font-family: 'Inter Tight';
    font-weight: 500;
    font-size: 0.9375rem;
    color: var(--ink-secondary);
    text-decoration: none;
    transition: color 140ms ease-out;
  }
  .stub-link:hover {
    color: var(--ink-primary);
  }
</style>
