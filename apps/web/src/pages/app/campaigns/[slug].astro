---
import { createClient } from '@supabase/supabase-js';
import AppLayout from '../../../layouts/AppLayout.astro';
import CampaignDetail from '../../../components/islands/CampaignDetail.tsx';

export async function getStaticPaths() {
  // Fetch slugs from Supabase at build time using the anon key (campaigns
  // table is public-read via RLS, so the anon key is sufficient). Avoids
  // the maintenance cost of a hardcoded slug list drifting from the DB.
  // Anon key is available as a PUBLIC_ env var on Cloudflare Pages builds.
  const url = (import.meta.env.PUBLIC_SUPABASE_URL as string | undefined)?.trim();
  const key = (import.meta.env.PUBLIC_SUPABASE_ANON_KEY as string | undefined)?.trim();
  if (!url || !key) {
    console.warn(
      '[campaigns/[slug]] PUBLIC_SUPABASE_URL or PUBLIC_SUPABASE_ANON_KEY missing at build time — no campaign pages will be generated.',
    );
    return [];
  }
  const client = createClient(url, key, { auth: { persistSession: false } });
  const { data, error } = await client.from('campaigns').select('slug');
  if (error) {
    console.warn('[campaigns/[slug]] campaigns query failed:', error.message);
    return [];
  }
  return (data ?? []).map((row: { slug: string }) => ({
    params: { slug: row.slug },
  }));
}

const { slug } = Astro.params;
---

<AppLayout title={`${slug} — Ringdocket`}>
  <div class="campaign-detail-page">
    <CampaignDetail client:load slug={slug!} />
  </div>
</AppLayout>

<style is:global>
  .campaign-detail-page {
    max-width: 900px;
  }
  .campaign-article-head {
    margin-bottom: 2.5rem;
  }
  .campaign-case-id {
    font-family: 'JetBrains Mono';
    font-size: 0.6875rem;
    color: var(--ink-byline);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 0.75rem;
  }
  .campaign-article-h1 {
    font-family: 'Bricolage Grotesque';
    font-weight: 700;
    font-size: clamp(2rem, 4.2vw, 2.75rem);
    line-height: 1.05;
    letter-spacing: -0.015em;
    color: var(--ink-primary);
    margin: 0 0 0.5rem;
  }
  .campaign-byline {
    font-family: 'Newsreader';
    font-style: italic;
    font-size: 1rem;
    color: var(--ink-byline);
    margin: 0 0 1.25rem;
  }
  .campaign-chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }
  .campaign-chip {
    font-family: 'Inter Tight';
    font-weight: 500;
    font-size: 0.75rem;
    padding: 0.3125rem 0.625rem;
    border-radius: 4px;
    letter-spacing: 0.02em;
  }
  .campaign-chip.corroborated {
    background: color-mix(in srgb, var(--signal-corroborated, #3f7c5a) 14%, var(--surface-raised));
    color: var(--signal-corroborated, #3f7c5a);
    border: 1px solid color-mix(in srgb, var(--signal-corroborated, #3f7c5a) 25%, transparent);
  }
  .campaign-chip.pending {
    background: var(--surface-inset);
    color: var(--ink-secondary);
    border: 1px solid var(--rule);
  }
  .campaign-chip.retired {
    background: color-mix(in srgb, var(--accent-signal) 10%, var(--surface-raised));
    color: var(--accent-signal);
    border: 1px solid color-mix(in srgb, var(--accent-signal) 22%, transparent);
  }
  .campaign-narrative {
    font-family: 'Newsreader';
    font-size: 1.0625rem;
    line-height: 1.65;
    color: var(--ink-primary);
    margin: 0 0 1.5rem;
    max-width: 70ch;
  }
  .campaign-source-chip {
    font-family: 'JetBrains Mono';
    font-size: 0.6875rem;
    color: var(--ink-byline);
    padding: 0.625rem 0.875rem;
    background: var(--surface-inset);
    border: 1px solid var(--rule-subtle);
    border-radius: 4px;
    line-height: 1.55;
  }

  .campaign-ledger-section {
    background: var(--surface-raised);
    border: 1px solid var(--rule);
    border-radius: 8px;
    padding: 1.25rem 1.375rem;
    margin-bottom: 1.5rem;
  }
  .campaign-ledger-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1rem;
    padding-bottom: 0.625rem;
    border-bottom: 1px solid var(--rule);
  }
  .campaign-ledger-title {
    font-family: 'Inter Tight';
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-primary);
    margin: 0;
  }
  .campaign-ledger-count {
    font-family: 'JetBrains Mono';
    font-size: 0.75rem;
    color: var(--ink-byline);
  }
  .campaign-ledger-controls {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.625rem;
    margin-bottom: 0.875rem;
  }
  @media (max-width: 520px) {
    .campaign-ledger-controls {
      grid-template-columns: 1fr;
    }
  }
  .campaign-ledger-search {
    display: block;
  }
  .campaign-ledger-search input {
    width: 100%;
    font-family: 'JetBrains Mono';
    font-size: 0.8125rem;
    color: var(--ink-primary);
    background: var(--surface-inset);
    border: 1px solid var(--rule);
    border-radius: 4px;
    padding: 0.5rem 0.625rem;
    line-height: 1.2;
    transition: border-color 140ms ease-out, background 140ms ease-out;
  }
  .campaign-ledger-search input::placeholder {
    color: var(--ink-byline);
  }
  .campaign-ledger-search input:focus {
    outline: none;
    border-color: var(--ink-secondary);
    background: var(--surface-raised);
  }
  .campaign-ledger-sort select {
    font-family: 'Inter Tight';
    font-weight: 500;
    font-size: 0.8125rem;
    color: var(--ink-primary);
    background: var(--surface-inset);
    border: 1px solid var(--rule);
    border-radius: 4px;
    padding: 0.5rem 1.75rem 0.5rem 0.625rem;
    line-height: 1.2;
    cursor: pointer;
    appearance: none;
    -webkit-appearance: none;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='10' height='6' viewBox='0 0 10 6' fill='none'><path d='M1 1L5 5L9 1' stroke='%23666' stroke-width='1.25' stroke-linecap='round' stroke-linejoin='round'/></svg>");
    background-repeat: no-repeat;
    background-position: right 0.625rem center;
    transition: border-color 140ms ease-out;
  }
  .campaign-ledger-sort select:focus {
    outline: none;
    border-color: var(--ink-secondary);
  }
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .campaign-ledger {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .campaign-ledger[aria-busy='true'] {
    opacity: 0.55;
    transition: opacity 140ms ease-out;
  }

  .campaign-ledger-more {
    display: flex;
    justify-content: center;
    padding-top: 0.875rem;
    margin-top: 0.25rem;
    border-top: 1px solid var(--rule-subtle);
  }
  .campaign-ledger-more-btn {
    font-family: 'Inter Tight';
    font-weight: 500;
    font-size: 0.8125rem;
    letter-spacing: 0.01em;
    color: var(--ink-primary);
    background: var(--surface-inset);
    border: 1px solid var(--rule);
    border-radius: 4px;
    padding: 0.5rem 1rem;
    cursor: pointer;
    transition: background 140ms ease-out, border-color 140ms ease-out, color 140ms ease-out;
  }
  .campaign-ledger-more-btn:hover:not(:disabled) {
    background: var(--surface-raised);
    border-color: var(--ink-secondary);
  }
  .campaign-ledger-more-btn:disabled {
    color: var(--ink-byline);
    cursor: progress;
  }
  .campaign-ledger-row {
    display: grid;
    grid-template-columns: minmax(120px, 1fr) auto auto;
    gap: 1rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--rule-subtle);
    align-items: baseline;
    font-family: 'JetBrains Mono';
    font-size: 0.8125rem;
  }
  .campaign-ledger-row:last-child {
    border-bottom: none;
  }
  .campaign-ledger-phone {
    color: var(--ink-mono);
  }
  .campaign-ledger-meta {
    color: var(--ink-byline);
    font-size: 0.75rem;
    white-space: nowrap;
  }
  .campaign-ledger-score {
    color: var(--ink-secondary);
    font-size: 0.75rem;
    white-space: nowrap;
  }
  .score-label {
    color: var(--ink-byline);
    font-size: 0.6875rem;
    margin-left: 0.25em;
  }
  .campaign-ledger-empty {
    font-family: 'Newsreader';
    font-style: italic;
    font-size: 0.9375rem;
    color: var(--ink-byline);
    margin: 0;
    padding: 1.25rem 0;
  }

  .campaign-article-foot {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-top: 1rem;
    border-top: 1px solid var(--rule-subtle);
  }
  .campaign-back, .campaign-delist {
    font-family: 'Inter Tight';
    font-weight: 500;
    font-size: 0.875rem;
    color: var(--ink-secondary);
    text-decoration: none;
    transition: color 140ms ease-out;
  }
  .campaign-back:hover, .campaign-delist:hover {
    color: var(--ink-primary);
  }

  .campaign-skel > div {
    background: linear-gradient(
      90deg,
      var(--surface-inset) 0%,
      color-mix(in srgb, var(--surface-inset) 60%, var(--surface-raised)) 50%,
      var(--surface-inset) 100%
    );
    border-radius: 3px;
    animation: rd-skel 1.4s ease-in-out infinite;
  }
  .campaign-skel-title { width: 70%; height: 48px; margin-bottom: 0.75rem; }
  .campaign-skel-byline { width: 45%; height: 18px; margin-bottom: 1.5rem; }
  .campaign-skel-summary { width: 95%; height: 18px; margin-bottom: 0.5rem; }
  .campaign-skel-summary.short { width: 70%; }

  .campaign-notfound {
    padding: 3rem 0;
  }
  .campaign-notfound h1 {
    font-family: 'Bricolage Grotesque';
    font-weight: 700;
    font-size: 2rem;
    margin: 0 0 1rem;
    color: var(--ink-primary);
  }
  .campaign-error {
    color: #b1271b;
    font-family: 'Newsreader';
  }
</style>
