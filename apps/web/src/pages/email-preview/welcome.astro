---
// Welcome email — sent after first successful sign-in.
//
// Subject: "Welcome to the ledger"
// Inline CSS only. Web-safe font stack.
//
// Branded fonts (Bricolage Grotesque, Newsreader) could be added via
// Google Fonts <link> tags later — at the cost of a network fetch and
// Outlook compatibility issues.
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="x-apple-disable-message-reformatting" />
    <title>Welcome to the ledger</title>
  </head>
  <body style="margin:0;padding:0;background:#F7F3EA;font-family:Georgia,'Times New Roman',serif;color:#1B1F27;-webkit-font-smoothing:antialiased;">

    <div style="display:none;max-height:0;overflow:hidden;mso-hide:all;font-size:1px;line-height:1px;color:#F7F3EA;">
      You&rsquo;re in. The block list is already syncing to your phone.
    </div>

    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#F7F3EA;">
      <tr>
        <td align="center" style="padding:32px 16px;">

          <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" style="width:100%;max-width:600px;background:#FFFFFF;border:1px solid #D8D0BE;border-radius:6px;">

            <!-- Masthead -->
            <tr>
              <td style="padding:28px 32px 16px;border-bottom:1px solid #D8D0BE;">
                <span style="font-family:Georgia,'Times New Roman',serif;font-size:22px;font-weight:700;letter-spacing:-0.01em;color:#1B1F27;">Ringdocket</span><span style="font-family:Georgia,'Times New Roman',serif;font-size:22px;font-weight:700;color:#C2370A;">.</span>
                <span style="display:block;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;font-size:11px;text-transform:uppercase;letter-spacing:0.1em;color:#8D8875;margin-top:6px;">Welcome</span>
              </td>
            </tr>

            <!-- Hero -->
            <tr>
              <td style="padding:36px 32px 8px;">
                <h1 style="margin:0 0 16px;font-family:Georgia,'Times New Roman',serif;font-size:28px;line-height:1.15;font-weight:700;color:#1B1F27;letter-spacing:-0.01em;">
                  Welcome to the ledger.
                </h1>
                <p style="margin:0 0 8px;font-family:Georgia,'Times New Roman',serif;font-size:18px;line-height:1.55;color:#1B1F27;">
                  You&rsquo;re in. The block list &mdash; 28,500+ corroborated numbers &mdash; is already syncing to your phone.
                </p>
              </td>
            </tr>

            <!-- Hairline rule (the one accent allowed in a hero) -->
            <tr>
              <td style="padding:0 32px;">
                <div style="height:2px;width:48px;background:#C2370A;opacity:0.6;margin:20px 0 28px;"></div>
              </td>
            </tr>

            <!-- Section 1 — How reports build the list -->
            <tr>
              <td style="padding:0 32px 24px;">
                <p style="margin:0 0 6px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;font-size:11px;text-transform:uppercase;letter-spacing:0.1em;color:#8D8875;">
                  01 &middot; How the list grows
                </p>
                <p style="margin:0;font-family:Georgia,'Times New Roman',serif;font-size:16px;line-height:1.65;color:#1B1F27;">
                  A number lands on the public block list when three different verified accounts flag it inside a rolling 14-day window. No two accounts can share a device fingerprint or IP block. That&rsquo;s the corroboration rule, and it&rsquo;s why the list earns trust instead of asking for it.
                </p>
              </td>
            </tr>

            <!-- Section 2 — Dashboard -->
            <tr>
              <td style="padding:0 32px 24px;">
                <p style="margin:0 0 6px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;font-size:11px;text-transform:uppercase;letter-spacing:0.1em;color:#8D8875;">
                  02 &middot; Your dashboard
                </p>
                <p style="margin:0 0 12px;font-family:Georgia,'Times New Roman',serif;font-size:16px;line-height:1.65;color:#1B1F27;">
                  Track which campaigns you&rsquo;ve fought, see which of your reports corroborated, and watch your first-flag credits accumulate.
                </p>
                <p style="margin:0;">
                  <a href="https://ringdocket.com/app/home" style="font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;font-size:14px;color:#1B1F27;text-decoration:none;border-bottom:1px solid #1B1F27;padding-bottom:1px;">
                    Open the dashboard &rarr;
                  </a>
                </p>
              </td>
            </tr>

            <!-- Section 3 — iOS app -->
            <tr>
              <td style="padding:0 32px 32px;">
                <p style="margin:0 0 6px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;font-size:11px;text-transform:uppercase;letter-spacing:0.1em;color:#8D8875;">
                  03 &middot; The iOS app
                </p>
                <p style="margin:0 0 12px;font-family:Georgia,'Times New Roman',serif;font-size:16px;line-height:1.65;color:#1B1F27;">
                  Install the Call Directory extension, flip it on in Settings, and the corroborated block list goes live on your phone. Updates roll silently in the background.
                </p>
                <p style="margin:0;">
                  <a href="https://ringdocket.com/ios" style="font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;font-size:14px;color:#1B1F27;text-decoration:none;border-bottom:1px solid #1B1F27;padding-bottom:1px;">
                    Get the iPhone app &rarr;
                  </a>
                </p>
              </td>
            </tr>

            <!-- CTA -->
            <tr>
              <td style="padding:0 32px 36px;">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td align="center" bgcolor="#1B1F27" style="border-radius:6px;">
                      <a href="https://ringdocket.com/app/home"
                         style="display:inline-block;padding:13px 24px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;font-size:15px;font-weight:500;color:#F7F3EA;text-decoration:none;border-radius:6px;background:#1B1F27;">
                        File your first report
                      </a>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- Close -->
            <tr>
              <td style="padding:0 32px 32px;">
                <p style="margin:0;font-family:Georgia,'Times New Roman',serif;font-size:16px;line-height:1.65;color:#5C5D5F;font-style:italic;">
                  Thanks for showing up.
                </p>
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td style="padding:20px 32px 28px;border-top:1px solid #D8D0BE;background:#F7F3EA;">
                <p style="margin:0 0 8px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;font-size:12px;line-height:1.55;color:#8D8875;">
                  Ringdocket &middot; a product of LIGHTHOUSE 27 LLC
                </p>
                <p style="margin:0 0 8px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;font-size:12px;line-height:1.55;color:#8D8875;">
                  [TODO: Add LIGHTHOUSE 27 LLC mailing address]
                </p>
                <p style="margin:0 0 4px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;font-size:12px;line-height:1.55;color:#8D8875;">
                  You received this email because you created a Ringdocket account.
                </p>
                <p style="margin:0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;font-size:12px;line-height:1.55;color:#8D8875;">
                  <a href="https://ringdocket.com/account/email-preferences" style="color:#1B1F27;text-decoration:underline;">Manage email preferences</a> &middot;
                  <a href="[TODO: unsubscribe link from SendGrid]" style="color:#1B1F27;text-decoration:underline;">Unsubscribe</a>
                </p>
              </td>
            </tr>

          </table>

        </td>
      </tr>
    </table>

  </body>
</html>
