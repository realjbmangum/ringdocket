---
import Base from '../layouts/Base.astro';
import AuthForm from '../components/islands/AuthForm.tsx';
---

<Base title="Sign in — Ringdocket" description="Sign in to your Ringdocket dashboard.">
  <main class="login-main">
    <div class="login-card">
      <p class="login-kicker">Sign in</p>
      <h1 class="login-h1">
        Welcome back to <em>the ledger.</em>
      </h1>
      <p class="login-lead">
        Enter your email and we'll send a one-time sign-in link. No password
        to remember.
      </p>
      <AuthForm client:load />
      <p class="login-foot">
        New here? Same form — we'll create an account on first sign-in.
      </p>
    </div>
  </main>
</Base>

<style>
  .login-main {
    max-width: 560px;
    margin: 0 auto;
    padding: clamp(3rem, 10vw, 6rem) clamp(1rem, 3vw, 2rem);
  }
  .login-card {
    background: var(--surface-raised);
    border: 1px solid var(--rule);
    border-radius: 10px;
    padding: clamp(1.75rem, 4vw, 2.5rem);
  }
  .login-kicker {
    font-family: 'JetBrains Mono';
    font-size: 0.75rem;
    color: var(--accent-signal);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 0.875rem;
  }
  .login-h1 {
    font-family: 'Bricolage Grotesque';
    font-weight: 700;
    font-size: clamp(1.75rem, 3.5vw, 2.25rem);
    line-height: 1.08;
    letter-spacing: -0.01em;
    margin: 0 0 0.75rem;
    color: var(--ink-primary);
  }
  .login-h1 em {
    font-style: italic;
    font-family: 'Newsreader';
    font-weight: 500;
    color: var(--ink-secondary);
  }
  .login-lead {
    font-family: 'Newsreader';
    font-size: 1rem;
    line-height: 1.55;
    color: var(--ink-secondary);
    margin: 0 0 1.75rem;
    max-width: 48ch;
  }
  .login-foot {
    font-family: 'JetBrains Mono';
    font-size: 0.75rem;
    color: var(--ink-byline);
    margin: 1.5rem 0 0;
    padding-top: 1.25rem;
    border-top: 1px solid var(--rule-subtle);
  }

  :global(.auth-form) {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  :global(.auth-label) {
    font-family: 'Inter Tight';
    font-weight: 500;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-secondary);
  }
  :global(.auth-input) {
    font-family: 'JetBrains Mono';
    font-size: 0.9375rem;
    padding: 0.75rem 0.875rem;
    border: 1px solid var(--rule);
    border-radius: 6px;
    background: var(--surface-paper);
    color: var(--ink-primary);
    transition: border-color 140ms ease-out;
  }
  :global(.auth-input:focus) {
    outline: none;
    border-color: var(--ink-primary);
  }
  :global(.auth-submit) {
    font-family: 'Inter Tight';
    font-weight: 500;
    font-size: 0.9375rem;
    padding: 0.75rem 1rem;
    border-radius: 6px;
    border: 1px solid transparent;
    background: var(--ink-primary);
    color: var(--surface-paper);
    cursor: pointer;
    transition: background 140ms ease-out;
  }
  :global(.auth-submit:hover:not(:disabled)) {
    background: #2a2f3a;
  }
  :global(.auth-submit:disabled) {
    opacity: 0.55;
    cursor: not-allowed;
  }
  :global(.auth-error) {
    font-family: 'Newsreader';
    font-size: 0.875rem;
    color: #b1271b;
    margin: 0;
  }
  :global(.auth-help) {
    font-family: 'Newsreader';
    font-size: 0.8125rem;
    color: var(--ink-byline);
    margin: 0.25rem 0 0;
  }
  :global(.auth-sent) {
    padding: 1rem 1.125rem;
    background: var(--surface-inset);
    border-left: 2px solid var(--accent-signal);
    border-radius: 4px;
  }
  :global(.auth-sent-head) {
    font-family: 'Newsreader';
    font-style: italic;
    font-size: 1.0625rem;
    color: var(--ink-primary);
    margin: 0 0 0.375rem;
  }
  :global(.auth-sent-body) {
    font-family: 'Newsreader';
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--ink-secondary);
    margin: 0 0 0.75rem;
  }
  :global(.auth-link) {
    font-family: 'JetBrains Mono';
    font-size: 0.75rem;
    color: var(--ink-byline);
    background: transparent;
    border: none;
    padding: 0;
    cursor: pointer;
    text-decoration: underline;
  }
  :global(.auth-link:hover) {
    color: var(--ink-primary);
  }
</style>
