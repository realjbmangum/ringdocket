---
import Base from '../layouts/Base.astro';

const requested = Astro.url?.pathname ?? '/';
---

<Base
  title="Not found — Ringdocket"
  description="That page hasn't been written yet. Try the home page, pricing, or a number search."
>
  <main class="prose-page hero">
    <p class="kicker mono">404 · Page not found</p>
    <h1>That page hasn't been written yet.</h1>
    <p class="lead">
      You followed a link or typed a URL that doesn't lead anywhere on
      Ringdocket. Most of the time that means we haven't shipped it. Sometimes
      it means a typo. Either way, here are the doors that <em>are</em> open.
    </p>

    <div class="requested">
      <span class="requested-label">You asked for</span>
      <code class="requested-path mono">{requested}</code>
    </div>

    <ul class="link-list">
      <li><a href="/">Home</a> &mdash; what Ringdocket is, who it's for.</li>
      <li><a href="/pricing">Pricing</a> &mdash; Free, Full, and the 500-cap Founding Flagger offer.</li>
      <li><a href="/campaigns">Campaigns</a> &mdash; the active spam rings on the public ledger.</li>
      <li><a href="/methodology">Methodology</a> &mdash; how a number gets onto the block list.</li>
      <li><a href="/report-an-error">Report an error</a> &mdash; if your number was incorrectly flagged.</li>
    </ul>

    <p class="hint">
      If you came looking for a phone number, try a URL of the form
      <code class="mono">/number/[10-digit-phone]</code> &mdash; for example,
      <code class="mono">/number/4025550142</code>.
    </p>
  </main>
</Base>

<style>
  .prose-page {
    max-width: 720px;
    margin: 0 auto;
    padding: clamp(2.5rem, 6vw, 5rem) clamp(1rem, 3vw, 2rem) 5rem;
  }
  .kicker {
    font-size: 0.75rem;
    color: var(--accent-signal);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 0.875rem;
  }
  h1 {
    font-family: 'Bricolage Grotesque';
    font-weight: 700;
    font-size: clamp(2rem, 4.5vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--ink-primary);
    margin: 0 0 1rem;
  }
  .lead {
    font-family: 'Newsreader';
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--ink-secondary);
    max-width: 58ch;
    margin: 0 0 2rem;
  }
  .lead em {
    font-style: italic;
    color: var(--ink-primary);
  }
  .requested {
    background: var(--surface-raised);
    border: 1px solid var(--rule);
    border-radius: 8px;
    padding: 0.875rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.875rem;
    flex-wrap: wrap;
    margin: 0 0 2.5rem;
  }
  .requested-label {
    font-family: 'Inter Tight';
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-byline);
  }
  .requested-path {
    font-size: 0.875rem;
    color: var(--ink-primary);
    word-break: break-all;
  }
  .link-list {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    font-family: 'Newsreader';
    font-size: 1rem;
    line-height: 1.65;
    color: var(--ink-secondary);
  }
  .link-list li {
    padding: 0.625rem 0;
    border-bottom: 1px dotted var(--rule-subtle);
  }
  .link-list li:last-child {
    border-bottom: none;
  }
  .link-list a {
    font-family: 'Inter Tight';
    font-weight: 500;
    color: var(--ink-primary);
    text-decoration: none;
    border-bottom: 1px solid var(--rule);
  }
  .link-list a:hover {
    border-bottom-color: var(--ink-primary);
  }
  .hint {
    font-family: 'Newsreader';
    font-style: italic;
    font-size: 0.9375rem;
    color: var(--ink-byline);
    margin: 0;
  }
  .hint .mono,
  .hint code {
    font-style: normal;
    font-size: 0.8125rem;
    background: var(--surface-inset);
    padding: 0.125rem 0.375rem;
    border-radius: 3px;
    color: var(--ink-mono);
  }
</style>
