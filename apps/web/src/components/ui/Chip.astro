---
// Chip — state indicator primitive.
// Variants: flag (burnt orange), corroborated (deep moss), pending (olive-tan dashed).
// Size: sm | md (default).
// Pending uses a DASHED border intentionally — "unfinished" without a word.
// See docs/DESIGN-SYSTEM.md §2 (state chip spec) and §7 (component patterns).

interface Props {
  variant: 'flag' | 'corroborated' | 'pending';
  size?: 'sm' | 'md';
  class?: string;
}

const { variant, size = 'md', class: className = '' } = Astro.props;
---

<span class:list={['chip', `chip-${variant}`, `chip-${size}`, className]}>
  <slot />
</span>

<style>
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
    font-family: 'Inter Tight';
    font-weight: 500;
    letter-spacing: 0.02em;
    line-height: 1.3;
    white-space: nowrap;
    border-radius: 4px;
  }
  .chip-sm {
    font-size: 0.625rem;
    padding: 2px 6px;
  }
  .chip-md {
    font-size: 0.6875rem;
    padding: 3px 8px;
    border-radius: 6px;
  }
  .chip-flag {
    background: color-mix(in srgb, var(--signal-flag) 12%, transparent);
    color: var(--signal-flag);
    border: 1px solid color-mix(in srgb, var(--signal-flag) 35%, transparent);
  }
  .chip-corroborated {
    background: color-mix(in srgb, var(--signal-corroborated) 12%, transparent);
    color: var(--signal-corroborated);
    border: 1px solid color-mix(in srgb, var(--signal-corroborated) 35%, transparent);
  }
  .chip-pending {
    background: transparent;
    color: var(--muted-pending);
    border: 1px dashed var(--muted-pending);
  }
</style>
